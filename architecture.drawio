<mxfile host="app.diagrams.net">
  <diagram id="archi" name="Architecture">
    <mxGraphModel dx="800" dy="600" grid="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Titre -->
        <mxCell id="titre" value="Architecture générale" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="280" y="10" width="300" height="30"/>
        </mxCell>
        <!-- Acteurs -->
        <mxCell id="admin" value="Administrateur" style="ellipse;fillColor=#1B2A4A;fontColor=white;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="50" y="80" width="100" height="40"/>
        </mxCell>
        <mxCell id="teacher" value="Enseignant" style="ellipse;fillColor=#4A7DC9;fontColor=white;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="50" y="160" width="100" height="40"/>
        </mxCell>
        <mxCell id="parent" value="Parent" style="ellipse;fillColor=#2E7D32;fontColor=white;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="50" y="240" width="100" height="40"/>
        </mxCell>
        <!-- Frontend -->
        <mxCell id="frontend" value="Frontend React (Vite)" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="250" y="70" width="180" height="200"/>
        </mxCell>
        <mxCell id="fe1" value="AdminLayout&#10;/admin/*" style="rounded=1;fillColor=#C5CAE9;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="270" y="100" width="140" height="30"/>
        </mxCell>
        <mxCell id="fe2" value="TeacherLayout&#10;/teacher/*" style="rounded=1;fillColor=#C5CAE9;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="270" y="160" width="140" height="30"/>
        </mxCell>
        <mxCell id="fe3" value="ParentLayout&#10;/parent/*" style="rounded=1;fillColor=#C5CAE9;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="270" y="220" width="140" height="30"/>
        </mxCell>
        <!-- Backend -->
        <mxCell id="backend" value="API REST Express / TypeScript" style="rounded=1;whiteSpace=wrap;fillColor=#FFF3E0;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="530" y="70" width="180" height="200"/>
        </mxCell>
        <mxCell id="be1" value="Middlewares&#10;(auth, rôles)" style="rounded=1;fillColor=#FFE0B2;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="550" y="100" width="140" height="30"/>
        </mxCell>
        <mxCell id="be2" value="Contrôleurs&#10;(20+ modules)" style="rounded=1;fillColor=#FFE0B2;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="550" y="160" width="140" height="30"/>
        </mxCell>
        <mxCell id="be3" value="Prisma ORM" style="rounded=1;fillColor=#FFE0B2;fontSize=10;" parent="1" vertex="1">
          <mxGeometry x="550" y="220" width="140" height="30"/>
        </mxCell>
        <!-- Base -->
        <mxCell id="db" value="PostgreSQL" style="cylinder;fillColor=#1B2A4A;fontColor=white;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="560" y="320" width="120" height="50"/>
        </mxCell>
        <!-- Flèches acteurs → frontend -->
        <mxCell id="a1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;" parent="1" edge="1" source="admin" target="fe1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;" parent="1" edge="1" source="teacher" target="fe2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;" parent="1" edge="1" source="parent" target="fe3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Flèches frontend → backend -->
        <mxCell id="f1" value="HTTP / JSON" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="115"/>
            <mxPoint x="550" y="115"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="f2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="175"/>
            <mxPoint x="550" y="175"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="f3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=1;exitY=0.5;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="430" y="235"/>
            <mxPoint x="550" y="235"/>
          </mxGeometry>
        </mxCell>
        <!-- Flèche backend → DB -->
        <mxCell id="db1" value="SQL" style="edgeStyle=orthogonalEdgeStyle;rounded=0;exitX=0.5;exitY=1;" parent="1" edge="1" source="be3" target="db">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
